{
  "name": "narc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "corepack pnpm -r --filter './packages/**' build",
    "test": "corepack pnpm build && corepack pnpm -r --filter './packages/**' test",
    "typecheck": "corepack pnpm build && corepack pnpm -r --filter './packages/**' typecheck",
    "move:build": "sui move build --path packages/narc_policy",
    "move:test": "sui move test --path packages/narc_policy"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
